{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler pages dev",
    "deploy:live": "cp wrangler.live.jsonc wrangler.jsonc && npm run build && wrangler pages deploy",
    "deploy:teachers": "cp wrangler.teachers.jsonc wrangler.jsonc && npm run build && wrangler pages deploy",
    "dev:sandbox": "wrangler pages dev dist --d1=classdb --local --ip 0.0.0.0 --port 3000",
    "db:migrate:local": "wrangler d1 migrations apply classdb --local",
    "db:seed": "wrangler d1 execute classdb --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.11.9"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "vitest": "^3.1.0",
    "wrangler": "^4.4.0"
  }
}
